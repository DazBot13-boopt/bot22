# ── Mode ─────────────────────────────────────────────────────
# demo      = paper trading (aucun vrai argent)
# production = argent réel (configure PRIVATE_KEY + WALLET_ADDRESS)
MODE=demo

# ── Solde de départ en mode demo ─────────────────────────────
DEMO_INITIAL_BALANCE=500.0

# ── Montant copié par trade ($USDC) ──────────────────────────
FIXED_AMOUNT_PER_TRADE=5.0

# ── Budget journalier max ($USDC) ────────────────────────────
MAX_DAILY_SPEND=100.0

# ── Limite de trades copiés par semaine ──────────────────────
MAX_WEEKLY_TRADES=10

# ── Délai max entre le trade target et notre copie (secondes) ─
MAX_COPY_DELAY_SECONDS=60

# ── Intervalle de polling (secondes) ─────────────────────────
POLL_INTERVAL_SECONDS=5

# ── Seuil USDC investi par le trader avant de copier ─────────
# Petit trader ($2+) ou baleine ($150+) — adapte selon le profil
MIN_TOTAL_USDC=2.0

# ── Conviction minimum (0.65 = 65% du côté dominant) ─────────
MIN_CONVICTION_PCT=0.65

# ── Sécurisation des gains ────────────────────────────────────
# Si PnL réalisé >= ce seuil → montant par trade réduit
PROFIT_LOCK_THRESHOLD=50.0
# Ratio de réduction (0.5 = moitié du montant normal)
PROFIT_LOCK_RATIO=0.5

# ── Catégories de marchés à copier (séparées par virgule) ─────
# Finance, Crypto, Politics, Sports, World
TARGET_CATEGORIES=Finance

# ── Signal multi-traders actif ───────────────────────────────
MULTI_TRADER_BONUS=true

# ── Production uniquement ─────────────────────────────────────
# PRIVATE_KEY=0xTON_PRIVATE_KEY
# WALLET_ADDRESS=0xTON_WALLET
# SIGNATURE_TYPE=1  (0=EOA, 1=Proxy Polymarket, 2=Gnosis Safe)

# ── Dashboard (laisser vide = pas d'auth en local) ───────────
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=ton_mot_de_passe
