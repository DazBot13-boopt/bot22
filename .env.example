# ── MODE ──────────────────────────────────────────────────────
# "demo" = paper trading (argent fictif, sans risque)
# "production" = argent réel sur Polymarket
MODE=demo

# ── DEMO ──────────────────────────────────────────────────────
DEMO_INITIAL_BALANCE=500

# ── TRADING ───────────────────────────────────────────────────
FIXED_AMOUNT_PER_TRADE=5        # $ investi par trade copié
MAX_DAILY_SPEND=100             # budget maximum par jour ($)
MAX_WEEKLY_TRADES=10            # nombre max de trades par semaine
MAX_COPY_DELAY_SECONDS=60       # ignorer les trades > Xs de retard
POLL_INTERVAL_SECONDS=5         # fréquence de polling (secondes)

# ── FILTRES ────────────────────────────────────────────────────
TARGET_CATEGORIES=Finance,Crypto  # catégories à copier (virgule séparées)
MIN_TOTAL_USDC=1                  # montant min USDC du trader pour copier

# ── SÉCURISATION DES GAINS ─────────────────────────────────────
PROFIT_LOCK_THRESHOLD=50        # si PnL réalisé > 50$, réduit le montant
PROFIT_LOCK_RATIO=0.5           # réduit à 50% du montant normal

# ── DASHBOARD AUTH ─────────────────────────────────────────────
# Laisser DASHBOARD_PASSWORD vide = pas d'authentification (déconseillé en prod)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# ── PRODUCTION UNIQUEMENT ──────────────────────────────────────
# Laisser vide en mode demo
PRIVATE_KEY=
WALLET_ADDRESS=
# SIGNATURE_TYPE: 1 = compte polymarket.com (défaut), 0 = EOA MetaMask direct
SIGNATURE_TYPE=1
